# 后端监听地址
HOST=0.0.0.0
PORT=8000

# 日志级别
LOG_LEVEL=INFO

# ---- 存储后端选择 ----
# 可选值：json（默认）、sqlite、postgres
# json    → 内存 + ./data/profiles.json，零配置
# sqlite  → 本地 SQLite 数据库（推荐，零配置）
# postgres → PostgreSQL 数据库，需配置 STORAGE_DATABASE_URL
STORAGE_TYPE=sqlite

# JSON 存储路径（仅 STORAGE_TYPE=json 时生效）
DATA_PATH=./data/profiles.json

# SQLite 存储路径（仅 STORAGE_TYPE=sqlite 时生效）
STORAGE_SQLITE_PATH=./data/profiles.db

# PostgreSQL 连接字符串（仅 STORAGE_TYPE=postgres 时生效）
# 格式: postgresql://user:password@host:5432/database_name
STORAGE_DATABASE_URL=

# ---- LLM 默认配置（可被前端 metadata.llm_config 覆盖） ----
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000